# ============================================================
# Line ending normalization
# ============================================================

# Keep repository text files consistent across Windows, macOS and Linux.
* text=auto eol=lf

# Source code and documentation
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.pptx binary
*.xlsx binary
*.zip binary