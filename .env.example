# =====================================================================
# FridgeChef AI - local environment template
# =====================================================================
# Copy this file to .env for local development.
# Do not commit real credentials, tokens, passwords or private keys.
# credentials.json and blink_auth.json must stay local and are ignored by Git.
# =====================================================================

# Project and runtime
APP_NAME=FridgeChef_AI_Assistant
APP_ENV=dev
GOOGLE_APPLICATION_CREDENTIALS=credentials.json
GOOGLE_CLOUD_PROJECT=
PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1
# Production defaults to the global endpoint unless this is set to false.
VERTEX_PREFER_GLOBAL_ENDPOINT=false
GOOGLE_CLOUD_TEXT_LOCATION=
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_GENAI_USE_ENTERPRISE=TRUE
VERTEX_MODEL=gemini-2.5-flash
VERTEX_TEXT_FALLBACK_MODELS=gemini-2.5-flash-lite
# Search once for lists with 2+ fragments or for a single ambiguous reference.
MANUAL_GROUNDING_ENABLED=true
MANUAL_GROUNDING_MODE=multiple_or_ambiguous
MANUAL_GROUNDING_MIN_FRAGMENTS=2
# The Gen AI SDK retries 408/429/5xx with exponential backoff and jitter.
GENAI_RETRY_ATTEMPTS=4
GENAI_TIMEOUT_MS=120000
RECIPE_IMAGE_PROVIDER=gemini
VERTEX_IMAGE_MODEL=gemini-2.5-flash-image
VERTEX_IMAGEN_MODEL=imagen-4.0-generate-001
VERTEX_IMAGE_FALLBACK_MODELS=gemini-2.5-flash-image,imagen-4.0-generate-001,imagen-3.0-generate-002
GOOGLE_CLOUD_IMAGE_LOCATION=global
RECIPE_IMAGES_ENABLED=true
RECIPE_IMAGE_ASPECT_RATIO=4:3
RECIPE_IMAGE_SIZE=1K
RECIPE_IMAGE_OUTPUT_MIME_TYPE=image/jpeg
RECIPE_IMAGE_DEBUG=false

# Optional persistence
ALLOW_CHAT_PERSISTENCE=false
ALLOW_IMAGE_STORAGE=false
BUCKET_NAME=
FIRESTORE_DATABASE=(default)
FIRESTORE_COLLECTION=fridgechef_sessions

# Validation and encryption
ENCRYPTION_ENABLED=true
FRIDGECHEF_MASTER_KEY=
APP_ENCRYPTION_KEY=
MAX_IMAGE_MB=10
ALLOW_PUBLIC_CLOUD_RUN=true

# Optional MCP tools
MCP_ENABLED=false
MCP_SERVER_URL=http://localhost:8088/mcp
MCP_AUTH_TOKEN=change-me-local-token

# Optional internal camera integration
BLINK_ENABLED=false
BLINK_AUTH_FILE=blink_auth.json
BLINK_OUTPUT_FILE=photos/blink_latest.jpg
BLINK_MAX_PHOTO_AGE_SECONDS=120
BLINK_MAX_STALE_SECONDS=120

# Optional Python / UiPath automation
AUTOMATION_ENABLED=false
AUTOMATION_ENGINE=python
AUTOMATION_SEND_EMAIL=false
AUTOMATION_EMAIL_TO=

# Optional SMTP email
EMAIL_ENABLED=false
EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
